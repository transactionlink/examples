package com.example.transactionlink

/**
 * Configuration file for Transactionlink mobile app
 *
 * IMPORTANT: Copy this file to Config.kt and fill in your backend URL
 * Config.kt is ignored by git for security
 *
 * SECURITY NOTE: This app connects to your backend server which handles
 * API secrets securely. Never put API_KEY or API_SECRET in client code!
 *
 * To set up:
 * 1. Copy this file to Config.kt
 * 2. Deploy the backend (from server/node or server/python)
 * 3. Set BACKEND_URL to your deployed backend server URL
 *
 * For local development only:
 * - Android emulator: "http://10.0.2.2:8101"
 * - Physical device: "http://YOUR_LOCAL_IP:8101" (e.g., "http://192.168.1.100:8101")
 */
object Config {
    // Backend server URL - handles API authentication securely
    // Deploy your backend and put its URL here
    const val BACKEND_URL = "https://your-backend-server.com"

    // Widget Configuration
    const val WIDGET_BASE_URL = "https://widget.transactionlink.io"

    // For local widget development, uncomment and modify:
    // const val WIDGET_BASE_URL = "http://10.0.2.2:3000"
}

