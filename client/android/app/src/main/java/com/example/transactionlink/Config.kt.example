package com.example.transactionlink

/**
 * Configuration file for Transactionlink API
 *
 * IMPORTANT: Copy this file to Config.kt and fill in your credentials
 * Config.kt is ignored by git for security
 *
 * To set up:
 * 1. Copy this file to Config.kt
 * 2. Fill in API_KEY and API_SECRET from Transactionlink dashboard
 * 3. Set WORKFLOW_DEFINITION_ID to your workflow ID
 * 4. For local development, uncomment and set WIDGET_BASE_URL to your local URL
 */
object Config {
    // API Credentials - get from Transactionlink dashboard
    const val API_KEY = "your-api-key-here"
    const val API_SECRET = "your-api-secret-here"

    // Workflow Configuration - ID of the workflow to run
    const val WORKFLOW_DEFINITION_ID = "your-workflow-id-here"

    // Base URLs
    const val API_BASE_URL = "https://api.staging.transactionlink.io/"
    const val WIDGET_BASE_URL = "https://widget.staging.transactionlink.io"

    // For local development, uncomment and modify:
    // const val WIDGET_BASE_URL = "http://192.168.1.100:3000"

    // Locale for the widget
    const val LOCALE = "en"
}

